\citation{liu2024lost}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces ISR vs.\ document length for each model. \textsc  {Gemini-2.5-Flash}\xspace  (green) shows an increasing trend, \textsc  {GPT-4.1-mini}\xspace  (blue) shows a decreasing trend, and \textsc  {Claude-Sonnet-4}\xspace  (orange) is flat at 0\%. Error bars indicate 95\% Wilson score confidence intervals. The bare-injection condition (length 0) is shown but excluded from trend tests since no document is present.\relax }}{5}{figure.caption.4}\protected@file@percent }
\newlabel{fig:isr_vs_length}{{1}{5}{ISR vs.\ document length for each model. \geminiflash (green) shows an increasing trend, \gptmini (blue) shows a decreasing trend, and \claudesonnet (orange) is flat at 0\%. Error bars indicate 95\% Wilson score confidence intervals. The bare-injection condition (length 0) is shown but excluded from trend tests since no document is present.\relax }{figure.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces ISR by injection position for \textsc  {GPT-4.1-mini}\xspace  and \textsc  {Gemini-2.5-Flash}\xspace  (documents with length $\geq $ 100 words only). \textsc  {GPT-4.1-mini}\xspace  shows a significant primacy effect: beginning placement yields the highest ISR. \textsc  {Gemini-2.5-Flash}\xspace  shows no significant position effect, likely due to ceiling effects at high overall ISR.\relax }}{5}{figure.caption.5}\protected@file@percent }
\newlabel{fig:isr_by_position}{{2}{5}{ISR by injection position for \gptmini and \geminiflash (documents with length $\geq $ 100 words only). \gptmini shows a significant primacy effect: beginning placement yields the highest ISR. \geminiflash shows no significant position effect, likely due to ceiling effects at high overall ISR.\relax }{figure.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces ISR by context type (random vs.\ relevant filler) for \textsc  {GPT-4.1-mini}\xspace  and \textsc  {Gemini-2.5-Flash}\xspace  . Neither model shows a significant difference, contrary to the \textsc  {NINJA}\xspace  finding that relevant context amplifies attacks.\relax }}{6}{figure.caption.6}\protected@file@percent }
\newlabel{fig:isr_by_context}{{3}{6}{ISR by context type (random vs.\ relevant filler) for \gptmini and \geminiflash . Neither model shows a significant difference, contrary to the \ninja finding that relevant context amplifies attacks.\relax }{figure.caption.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Summary of hypothesis testing results. Arrows indicate direction of effect. ``--'' indicates the test is not applicable due to floor effects (0\% ISR everywhere).\relax }}{6}{table.caption.7}\protected@file@percent }
\newlabel{tab:hypotheses}{{3}{6}{Summary of hypothesis testing results. Arrows indicate direction of effect. ``--'' indicates the test is not applicable due to floor effects (0\% ISR everywhere).\relax }{table.caption.7}{}}
